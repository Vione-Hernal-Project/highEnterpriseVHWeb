PUBLIC_SITE_URL=https://your-production-domain.example
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Use one complete Ethereum Mainnet RPC URL only. Do not paste a provider URL inside itself.
ETHEREUM_MAINNET_RPC_URL=https://your-ethereum-mainnet-rpc-url
COINGECKO_SIMPLE_PRICE_ENDPOINT=https://api.coingecko.com/api/v3/simple/price
COINGECKO_DEMO_API_KEY=
NEXT_PUBLIC_MERCHANT_WALLET_ADDRESS=0xYourMerchantWalletAddress
# TODO(mainnet-launch): paste the deployed Ethereum Mainnet VHL token contract address.
NEXT_PUBLIC_VHL_TOKEN_ADDRESS=
# TODO(mainnet-launch): paste the Ethereum Mainnet USDC token contract address if USDC support stays enabled.
NEXT_PUBLIC_USDC_TOKEN_ADDRESS=
# TODO(mainnet-launch): paste the Ethereum Mainnet USDT token contract address if USDT support stays enabled.
NEXT_PUBLIC_USDT_TOKEN_ADDRESS=
# Set this to the email of the store-owner account if you want the saved dashboard wallet address
# to become the active checkout recipient.
STORE_OWNER_EMAILS=owner@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=Vione Hernal <no-reply@example.com>
STORE_NOTIFICATION_EMAIL=orders@example.com
